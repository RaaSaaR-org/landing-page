# Public site origin used in metadata, OpenGraph, JSON-LD, sitemap.
NEXT_PUBLIC_SITE_URL=https://emai.dev

# Google Analytics 4 Measurement ID. Looks like "G-XXXXXXXXXX".
# When unset, analytics stays completely dark (no GA script loaded).
# Get it from https://analytics.google.com -> Admin -> Data Streams.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Hotjar site ID (numeric). When unset, Hotjar stays off.
NEXT_PUBLIC_HOTJAR_ID=
